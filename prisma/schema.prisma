// Prisma 7.0.1
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GameUpdate {
  id          Int       @id @default(autoincrement())
  slug        String    @unique // "realm-divided"
  name        String    @unique // "Realm Divided"
  releaseDate DateTime? @db.Date // data do update principal
  description String?   @db.Text

  patches PatchNote[]

  @@index([slug])
}

// ─── Topo da hierarquia ────────────────────────────────────────────
model PatchNote {
  id           Int        @id @default(autoincrement())
  slug         String     @unique
  gameUpdateId Int
  gameUpdate   GameUpdate @relation(fields: [gameUpdateId], references: [id])
  patchName    String
  version      String? // null em hotfixes e patches sem versão explícita
  revision     String?
  date         String
  dateIso      DateTime   @db.Date
  description  String     @db.Text
  sourceUrl    String
  keywords     String[]

  sections Section[]

  @@index([gameUpdateId])
  @@index([dateIso])
  @@index([slug])
}

// ─── Seção (ex: "Combat Balance Changes", "Fixes") ────────────────
model Section {
  id          Int       @id @default(autoincrement())
  patchNoteId Int
  patchNote   PatchNote @relation(fields: [patchNoteId], references: [id], onDelete: Cascade)
  heading     String
  description String?   @db.Text
  items       Json      @default("[]") // objetos { text, stats?, subitems? }
  searchText  String    @db.Text

  subsections Subsection[]
  changes     Change[]

  @@index([patchNoteId])
  @@index([heading])
}

// ─── Subseção (ex: "Arcane Staffs" dentro de "Combat Balance Changes") ──
model Subsection {
  id          Int     @id @default(autoincrement())
  sectionId   Int
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  heading     String
  description String? @db.Text
  items       Json? // objetos { text, stats?, subitems? } — presente em patches gerais
  searchText  String  @db.Text

  changes Change[]

  @@index([sectionId])
  @@index([heading])
}

// ─── Change — unidade atômica de busca ───────────────────────────
model Change {
  id           Int         @id @default(autoincrement())
  sectionId    Int?
  section      Section?    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subsectionId Int?
  subsection   Subsection? @relation(fields: [subsectionId], references: [id], onDelete: Cascade)

  ability String   @db.Text
  rawText String   @db.Text
  notes   String[]

  searchText String @db.Text

  gameUpdateId      Int
  gameUpdateName    String
  patchSlug         String
  patchVersion      String? // null quando o patch não tem versão
  patchDate         DateTime @db.Date
  sectionHeading    String
  subsectionHeading String?

  stats Stat[]

  @@index([gameUpdateId])
  @@index([patchSlug])
  @@index([patchDate])
  @@index([sectionHeading])
  @@index([subsectionHeading])
}

// ─── Stat — valores numéricos de cada mudança ─────────────────────
model Stat {
  id       Int    @id @default(autoincrement())
  changeId Int
  change   Change @relation(fields: [changeId], references: [id], onDelete: Cascade)
  name     String
  from     String
  to       String

  @@index([changeId])
  @@index([name])
}
