    {
      "heading": "Other Changes and Improvements",
      "description": null,
      "items": [
        {
          "text": "The Claim Rewards UI has been reworked, with paging and scrolling added alongside other visual improvements"
        },
        {
          "text": "Custom Matches can now be initiated by a third party player. That player can act as an organizer who invites two teams, without taking part in the fight."
        },
        {
          "text": "Removed obsolete / outdated Castle Season Point Breakdown information from UIs"
        },
        {
          "text": "Guild Estates UI now shows HQ Qualification and Booster information for guilds who already have a Headquarters Hideout"
        },
        {
          "text": "Furniture can no longer be placed on top of loot bags"
        },
        {
          "text": "[MOBILE] Increased auto-target maximum range"
        }
      ],
      "subsections": [],
