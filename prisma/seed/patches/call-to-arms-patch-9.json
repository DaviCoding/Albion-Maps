    {
      "heading": "Corrupted Dungeon Changes",
      "description": "System changes and anti-reset mechanics.",
      "items": [
        "PvP shrine must be activated within 45 seconds",
        "All cooldowns reset at invasion start",
        "Healing Cast reduction increased from 10% to 20%",
        "Spike traps hitboxes improved",
        "Various mob behavior improvements"
      ],
      "searchable_text": "corrupted dungeon shrine cooldown healing traps mobs",
      "subsections": []
    },
    {
      "heading": "New Mob: Corrupted Mephit",
      "description": "Anti-reset mechanic to discourage prolonged disengagement.",
      "items": [
        "Spawns after prolonged PvP engagement",
        "Applies stacking Corruption debuff (max 25 stacks)",
        "Each stack reduces max health by 1% and slows after 5 stacks",
        "Triggers after 180s (Slayer) or 300s (others) plus player combat",
        "Respawns every 30 seconds during active combat"
      ],
      "searchable_text": "corrupted mephit anti reset debuff health slow",
      "subsections": []
    },
    {
      "heading": "Overcrowded Zone Changes",
      "description": "Reduced wait times for skipping zones.",
      "items": [
        "Zone skip cooldown reduced from 125s to 60s",
        "Overcrowded timer no longer fully resets on brief dips",
        "Improved overall skip reliability"
      ],
      "searchable_text": "zone skipping overcrowded cooldown",
      "subsections": []
    },
    {
      "heading": "Marketplace Improvements",
      "description": "Enhanced order notifications.",
      "items": [
        "Notifications now sent on manual order cancel",
        "Mails clarified as full-order summaries"
