      "searchable_text": "marketplace notifications cancel summary",
      "subsections": []
    },
    {
      "heading": "Faction Warfare Changes",
      "description": "Bandit Ringleader scaling update.",
      "items": [
        "Spawns support mobs every 20% HP lost",
