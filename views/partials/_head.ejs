<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — Albion Maps' : 'Albion Maps' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;900&family=EB+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style type="text/tailwindcss">
    @theme {
      --color-bg:           #06080a;
      --color-bg2:          #0b0e11;
      --color-surface:      #101417;
      --color-surface2:     #161b1f;
      --color-surface3:     #1c2228;
      --color-border:       #1f2428;
      --color-bordergold:   #3d3218;
      --color-gold:         #d4a847;
      --color-golddim:      #8a6e30;
      --color-goldglow:     rgba(212,168,71,0.10);
      --color-text:         #e2ddd6;
      --color-muted:        #8a9099;
      --color-dim:          #4a5058;
      --color-patch:        #6a9fd4;
      --color-patchbg:      #0f1e30;
      --font-display:       'Cinzel', Georgia, serif;
      --font-body:          'EB Garamond', Georgia, serif;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body {
      background-color: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 1.1rem;
      font-weight: 500;
      line-height: 1.7;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.045'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
    }

    /* ── Typography ── */
    .font-display { font-family: var(--font-display); }
    .font-body    { font-family: var(--font-body); }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.4s ease both; }
    .fade-up:nth-child(1)  { animation-delay: 0.03s; }
    .fade-up:nth-child(2)  { animation-delay: 0.07s; }
    .fade-up:nth-child(3)  { animation-delay: 0.11s; }
    .fade-up:nth-child(4)  { animation-delay: 0.15s; }
    .fade-up:nth-child(5)  { animation-delay: 0.19s; }
    .fade-up:nth-child(6)  { animation-delay: 0.23s; }
    .fade-up:nth-child(7)  { animation-delay: 0.27s; }
    .fade-up:nth-child(8)  { animation-delay: 0.31s; }
    .fade-up:nth-child(9)  { animation-delay: 0.35s; }
    .fade-up:nth-child(10) { animation-delay: 0.39s; }

    /* ── Card ── */
    .card-item {
      display: block;
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 1.25rem 1.5rem;
      text-decoration: none;
      transition: border-color 0.2s, background-color 0.2s;
    }
    .card-item:hover {
      border-color: var(--color-golddim);
      background-color: var(--color-surface2);
    }
    .card-item:hover .card-title { color: var(--color-gold); }

    .card-title {
      font-family: var(--font-display);
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--color-text);
      transition: color 0.2s;
      line-height: 1.3;
    }

    .card-date {
      font-size: 0.82rem;
      color: var(--color-dim);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
      font-weight: 500;
    }

    .card-summary {
      font-size: 0.98rem;
      color: var(--color-muted);
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      font-weight: 500;
    }

    /* ── Tags ── */
    .tag {
      font-family: var(--font-display);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.2rem 0.6rem;
      border-radius: 3px;
      border: 1px solid;
      text-decoration: none;
      display: inline-block;
    }
    .tag-patch  { background: var(--color-patchbg); color: var(--color-patch); border-color: rgba(106,159,212,0.25); }
    .tag-update { background: #201508; color: var(--color-gold); border-color: rgba(212,168,71,0.25); }
    .tag-parent {
      background: transparent;
      color: var(--color-muted);
      border-color: var(--color-border);
      transition: color 0.2s, border-color 0.2s;
    }
    .tag-parent:hover { color: var(--color-gold); border-color: var(--color-golddim); }

    /* ── Nav ── */
    .nav-link {
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-muted);
      text-decoration: none;
      padding: 0.4rem 0.85rem;
      border: 1px solid transparent;
      border-radius: 4px;
      transition: color 0.2s, border-color 0.2s, background-color 0.2s;
    }
    .nav-link:hover { color: var(--color-text); }
    .nav-link.active {
      color: var(--color-gold);
      border-color: var(--color-bordergold);
      background-color: var(--color-goldglow);
    }

    /* ── Section rule ── */
    .section-rule {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 2.5rem 0 1.5rem;
      color: var(--color-muted);
      font-family: var(--font-display);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    .section-rule::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--color-border);
    }

    /* ── Page heading ── */
    .page-label {
      font-family: var(--font-display);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--color-golddim);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
    }
    .page-label::before,
    .page-label::after {
      content: '';
      flex: 0 0 24px;
      height: 1px;
      background: var(--color-golddim);
    }

    .page-title {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 900;
      letter-spacing: 0.05em;
      color: var(--color-text);
      line-height: 1.1;
    }

    .page-meta {
      font-size: 0.92rem;
      color: var(--color-muted);
      margin-top: 0.4rem;
      font-weight: 500;
    }

    /* ── Detail heading ── */
    .detail-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2.1rem);
      font-weight: 900;
      letter-spacing: 0.04em;
      color: var(--color-text);
      line-height: 1.15;
    }

    .detail-date {
      font-size: 0.9rem;
      color: var(--color-muted);
      font-weight: 600;
    }

    .summary-block {
      margin-top: 1.25rem;
      padding: 1.1rem 1.4rem;
      background: var(--color-surface);
      border-left: 2px solid var(--color-golddim);
      border-radius: 0 4px 4px 0;
      font-size: 1rem;
      color: var(--color-muted);
      line-height: 1.7;
      font-weight: 500;
    }

    /* ── Back link ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-muted);
      text-decoration: none;
      margin-bottom: 2rem;
      transition: color 0.2s;
    }
    .back-link:hover { color: var(--color-gold); }

    /* ── Patch content ── */
    .content-section-title {
      font-family: var(--font-display);
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--color-gold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--color-bordergold);
    }

    .content-subject {
      font-family: var(--font-display);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--color-text);
      margin-bottom: 0.5rem;
    }

    .change-item {
      position: relative;
      padding-left: 1.3rem;
      font-size: 1rem;
      color: var(--color-muted);
      font-weight: 500;
      line-height: 1.6;
    }
    .change-item::before {
      content: '◆';
      position: absolute;
      left: 0;
      top: 0.55em;
      font-size: 0.36rem;
      color: var(--color-golddim);
    }

    /* ── Ads ── */
    .ad-leaderboard {
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: var(--color-surface);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: 0 1rem;
    }
    .ad-leaderboard-inner {
      width: 970px;
      max-width: 100%;
      height: 90px;
      background-color: var(--color-surface2);
      border: 1px dashed var(--color-border);
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-dim);
    }

    .ad-rect {
      width: 100%;
      height: 280px;
      background-color: var(--color-surface2);
      border: 1px dashed var(--color-border);
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-dim);
    }

    /* ── Buttons / inputs ── */
    .btn-search {
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      background: transparent;
      border: 1px solid var(--color-golddim);
      color: var(--color-gold);
      padding: 0.65rem 1.4rem;
      border-radius: 4px;
      cursor: pointer;
      transition: background-color 0.2s;
      white-space: nowrap;
    }
    .btn-search:hover { background-color: var(--color-goldglow); }

    .search-input {
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 500;
      padding: 0.6rem 1rem;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    .search-input:focus { border-color: var(--color-golddim); }
    .search-input::placeholder { color: var(--color-dim); }

    .filter-select {
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-muted);
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 0.45rem 0.8rem;
      outline: none;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .filter-select:focus { border-color: var(--color-golddim); }

    /* ── Pagination ── */
    .page-btn {
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 0.45rem 1rem;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-muted);
      transition: all 0.2s;
      display: inline-block;
    }
    .page-btn:hover {
      border-color: var(--color-golddim);
      color: var(--color-gold);
      background-color: var(--color-goldglow);
    }
    .page-btn-disabled {
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.45rem 1rem;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-dim);
      display: inline-block;
    }

    /* ── Mobile nav toggle ── */
    #mobile-menu { display: none; }
    #mobile-menu.open { display: flex; }

    /* ── Divider ── */
    .gold-divider {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 0;
    }
  </style>
</head>
<body class="min-h-screen">
