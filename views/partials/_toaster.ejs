<!-- Toast container -->
<div id="toaster" style="position:fixed;bottom:24px;right:24px;z-index:9000;display:flex;flex-direction:column;gap:8px;pointer-events:none;"></div>

<!-- Modal backdrop -->
<div id="modal-backdrop" onclick="closeModal()"
  style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(3px);z-index:9001;"></div>

<!-- Modal -->
<div id="modal"
  style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9002;width:min(580px,calc(100vw - 32px));max-height:80vh;overflow-y:auto;background:var(--color-surface2);border:1px solid var(--color-bordergold);border-radius:6px;box-shadow:0 20px 60px rgba(0,0,0,0.7);">
  <div id="modal-content"></div>
</div>

<style>
  @keyframes toastIn  { from { opacity:0; transform:translateX(14px) } to { opacity:1; transform:translateX(0) } }
  @keyframes toastOut { from { opacity:1 } to { opacity:0; transform:translateX(14px) } }
  @keyframes modalIn  { from { opacity:0; transform:translate(-50%,-47%) } to { opacity:1; transform:translate(-50%,-50%) } }

  .stat-row { display:flex; align-items:center; border-bottom:1px solid var(--color-border); }
  .stat-row:last-child { border-bottom:none; }
  .stat-name { flex:1; padding:8px 0; font-size:1rem; color:var(--color-muted); font-family:var(--font-body); font-weight:600; line-height:1.4; }
  .stat-from { padding:8px 10px; font-family:var(--font-display); font-size:0.72rem; font-weight:700; letter-spacing:0.05em; color:#c06060; text-decoration:line-through; white-space:nowrap; }
  .stat-arr  { color:var(--color-dim); font-size:0.75rem; padding:0 2px; }
  .stat-to   { padding:8px 10px; font-family:var(--font-display); font-size:0.72rem; font-weight:700; letter-spacing:0.05em; color:var(--color-text); white-space:nowrap; }

  .modal-label {
    font-family: var(--font-display);
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-golddim); margin-bottom: 0.6rem;
  }
</style>

<script>
  // ── Toast ─────────────────────────────────────────────────────────────────
  function toast(message, type) {
    type = type || 'success';
    var borders = { success:'#4a8c5c', error:'#8c4a4a', info:'var(--color-golddim)' };
    var icons   = { success:'✓', error:'✕', info:'◆' };
    var border  = borders[type] || borders.info;
    var icon    = icons[type]   || icons.info;
    var el = document.createElement('div');
    el.style.cssText = 'display:flex;align-items:center;gap:10px;padding:10px 14px;'
      + 'background:var(--color-surface2);border:1px solid var(--color-border);'
      + 'border-left:2px solid ' + border + ';border-radius:4px;'
      + 'font-family:var(--font-body);font-size:0.95rem;font-weight:500;color:var(--color-text);'
      + 'box-shadow:0 4px 20px rgba(0,0,0,0.5);pointer-events:auto;'
      + 'min-width:200px;max-width:300px;animation:toastIn 0.2s ease;';
    el.innerHTML = '<span style="color:' + border + ';font-size:0.75rem;flex-shrink:0;">' + icon + '</span>'
      + '<span>' + message + '</span>';
    document.getElementById('toaster').appendChild(el);
    setTimeout(function() {
      el.style.animation = 'toastOut 0.2s ease forwards';
      setTimeout(function() { el.remove(); }, 200);
    }, 2200);
  }

  // ── Copy ──────────────────────────────────────────────────────────────────
  function copyText(text, label) {
    var fallback = function() {
      var ta = document.createElement('textarea');
      ta.value = text; ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
      document.body.appendChild(ta); ta.select();
      try { document.execCommand('copy'); toast('Copied: ' + (label||''), 'success'); }
      catch(e) { toast('Copy failed', 'error'); }
      document.body.removeChild(ta);
    };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text)
        .then(function() { toast('Copied: ' + (label||''), 'success'); })
        .catch(fallback);
    } else { fallback(); }
  }

  // ── Modal ─────────────────────────────────────────────────────────────────
  function openModal(html) {
    document.getElementById('modal-content').innerHTML = html;
    document.getElementById('modal').style.animation = 'modalIn 0.2s ease';
    document.getElementById('modal-backdrop').style.display = 'block';
    document.getElementById('modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    document.getElementById('modal-backdrop').style.display = 'none';
    document.getElementById('modal').style.display = 'none';
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });

  // ── Change detail modal ───────────────────────────────────────────────────
  function showChange(data) {
    var hasStats = data.stats && data.stats.length > 0;
    var hasNotes = data.notes && data.notes.length > 0;

    var statsHtml = '';
    if (hasStats) {
      statsHtml = '<p class="modal-label">Stats</p>'
        + '<div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:4px;padding:0 1rem;margin-bottom:1.25rem;">'
        + data.stats.map(function(s) {
            return '<div class="stat-row">'
              + '<span class="stat-name">' + s.name + '</span>'
              + '<span class="stat-from">' + s.from + '</span>'
              + '<span class="stat-arr">→</span>'
              + '<span class="stat-to">' + s.to + '</span>'
              + '</div>';
          }).join('')
        + '</div>';
    }

    var notesHtml = '';
    if (hasNotes) {
      notesHtml = '<p class="modal-label">Notes</p>'
        + '<ul style="list-style:none;padding:0;margin:0 0 1.25rem;display:flex;flex-direction:column;gap:0.4rem;">'
        + data.notes.map(function(n) {
            return '<li class="change-item">' + n + '</li>';
          }).join('')
        + '</ul>';
    }

    var rawEsc   = (data.rawText  || '').replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,' ');
    var labelEsc = (data.ability  || '').replace(/\\/g,'\\\\').replace(/'/g,"\\'").substring(0,40);

    openModal(
      '<div style="padding:1.5rem;">'
        + '<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:1.25rem;padding-bottom:1rem;border-bottom:1px solid var(--color-border);">'
          + '<div>'
            + '<p class="modal-label" style="margin-bottom:0.4rem;">Ability</p>'
            + '<h3 style="font-family:var(--font-display);font-size:0.92rem;font-weight:700;color:var(--color-text);line-height:1.3;">'
              + (data.ability || '') + '</h3>'
          + '</div>'
          + '<button onclick="closeModal()" style="flex-shrink:0;padding:4px 9px;background:transparent;border:1px solid var(--color-border);border-radius:3px;color:var(--color-dim);cursor:pointer;font-family:var(--font-display);font-size:0.68rem;letter-spacing:0.1em;transition:all 0.15s;" onmouseover="this.style.color=\'var(--color-muted)\'" onmouseout="this.style.color=\'var(--color-dim)\'">ESC</button>'
        + '</div>'
        + statsHtml
        + notesHtml
        + '<div style="display:flex;justify-content:flex-end;gap:8px;padding-top:1rem;border-top:1px solid var(--color-border);">'
          + '<button onclick="copyText(\'' + rawEsc + '\',\'' + labelEsc + '\');closeModal()" class="btn-search" style="font-size:0.62rem;padding:0.45rem 1rem;">Copy &amp; Close</button>'
          + '<button onclick="closeModal()" style="font-family:var(--font-display);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;background:transparent;border:1px solid var(--color-border);color:var(--color-muted);padding:0.45rem 1rem;border-radius:4px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor=\'var(--color-bordergold)\'" onmouseout="this.style.borderColor=\'var(--color-border)\'">Close</button>'
        + '</div>'
      + '</div>'
    );
  }
</script>
