<% locals.currentPath='/search' ; locals.searchQuery=q || '' ; var title=q ? 'Search: ' + q : 'Search' ; function
  patchUrl(patchSlug, query) { if (!query) return '/patches/' + patchSlug; return '/patches/' + patchSlug + '?q=' +
  encodeURIComponent(query); } function escHtml(s) { return String(s || '' ) .replace(/&/g, '&amp;' )
  .replace(/</g, '&lt;' ) .replace( />/g, '&gt;')
.replace(/"/g, '&quot;');
}

function highlightSnippet(text, terms) {
if (!text || !terms || !terms.length) return escHtml(text);
var out = escHtml(text);
var colors = ['#d4a847','#6a9fd4','#e08070','#80c880'];
var bgs = ['rgba(212,168,71,0.22)','rgba(106,159,212,0.22)','rgba(180,100,80,0.22)','rgba(100,180,120,0.22)'];
terms.forEach(function(term, i) {
if (!term) return;
var re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
var bg = bgs[i % bgs.length];
var col = colors[i % colors.length];
out = out.replace(re, '<mark style="background:' + bg + ';color:' + col + ';border-radius:2px;padding:0 2px;">$1</mark>');
});
return out;
}

function filterUrl(overrides) {
var params = {
q: q || '',
kind: (meta.filters && meta.filters.kind) || 'all',
dateFrom: (meta.filters && meta.filters.dateFrom) || '',
dateTo: (meta.filters && meta.filters.dateTo) || '',
gameUpdate: (meta.filters && meta.filters.gameUpdate) || '',
page: '1',
};
Object.assign(params, overrides);
var parts = [];
for (var k in params) {
if (params[k]) parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(params[k]));
}
return '/search?' + parts.join('&');
}

var f = meta.filters || {};
var hasFilters = (f.kind && f.kind !== 'all') || f.dateFrom || f.dateTo || f.gameUpdate;
%>
<%- include('../partials/_head', { title: title }) %>
  <%- include('../partials/_header') %>

    <style>
      .result-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 1.1rem 1.25rem;
        transition: border-color 0.15s, background-color 0.15s;
        margin-bottom: 2px;
        cursor: pointer;
      }

      .result-card:hover {
        border-color: var(--color-golddim);
        background: var(--color-surface2);
      }

      .kind-badge {
        display: inline-block;
        font-family: var(--font-display);
        font-size: 0.52rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 2px 6px;
        border-radius: 2px;
        margin-right: 6px;
        vertical-align: middle;
      }

      .kind-badge--change {
        background: var(--color-patchbg);
        color: var(--color-patch);
      }

      .kind-badge--section {
        background: rgba(100, 180, 120, 0.15);
        color: #80c880;
      }

      .result-breadcrumb {
        display: flex;
        align-items: center;
        gap: 5px;
        flex-wrap: wrap;
        margin-bottom: 0.6rem;
        font-family: var(--font-display);
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-dim);
      }

      .result-breadcrumb .crumb-link {
        color: var(--color-dim);
        cursor: pointer;
        transition: color 0.15s;
      }

      .result-breadcrumb .crumb-link:hover {
        color: var(--color-golddim);
      }

      .result-breadcrumb .sep {
        color: var(--color-border);
      }

      .result-breadcrumb .section-crumb {
        color: var(--color-muted);
      }

      .result-ability {
        font-family: var(--font-display);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: var(--color-gold);
        line-height: 1.35;
        margin-bottom: 0.5rem;
      }

      .result-stat {
        display: inline-flex;
        align-items: center;
        background: var(--color-surface2);
        border: 1px solid var(--color-border);
        border-radius: 3px;
        overflow: hidden;
        font-family: var(--font-display);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        vertical-align: middle;
      }

      .rs-name {
        padding: 3px 6px;
        color: var(--color-muted);
        border-right: 1px solid var(--color-border);
      }

      .rs-from {
        padding: 3px 5px;
        color: #c06060;
        text-decoration: line-through;
      }

      .rs-arr {
        padding: 0 2px;
        color: var(--color-dim);
      }

      .rs-to {
        padding: 3px 6px;
        color: var(--color-text);
      }

      .result-note {
        font-size: 0.92rem;
        color: var(--color-muted);
        font-weight: 500;
        position: relative;
        padding-left: 1.1rem;
        line-height: 1.5;
      }

      .result-note::before {
        content: '◆';
        position: absolute;
        left: 0;
        top: 0.52em;
        font-size: 0.3rem;
        color: var(--color-golddim);
      }

      .section-desc {
        font-size: 0.88rem;
        color: var(--color-muted);
        font-style: italic;
        margin-bottom: 0.5rem;
        line-height: 1.5;
      }

      .section-items {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      .section-item {
        font-size: 0.87rem;
        color: var(--color-muted);
        position: relative;
        padding-left: 1.1rem;
        line-height: 1.5;
      }

      .section-item::before {
        content: '–';
        position: absolute;
        left: 0;
        color: var(--color-dim);
      }

      .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: var(--font-display);
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        border: 1px solid var(--color-border);
        color: var(--color-dim);
        padding: 0.22rem 0.65rem;
        border-radius: 3px;
        transition: all 0.15s;
        background: transparent;
        cursor: pointer;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .view-btn:hover {
        border-color: var(--color-golddim);
        color: var(--color-gold);
        background: var(--color-goldglow);
      }

      .filter-bar {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 1rem 1.1rem;
        margin-bottom: 1.25rem;
      }

      .filter-bar summary {
        font-family: var(--font-display);
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-golddim);
        cursor: pointer;
        user-select: none;
        display: flex;
        align-items: center;
        gap: 6px;
        list-style: none;
      }

      .filter-bar summary::marker,
      .filter-bar summary::-webkit-details-marker {
        display: none;
      }

      .filter-bar summary .arrow {
        font-size: 0.7rem;
        transition: transform 0.2s;
      }

      .filter-bar[open] summary .arrow {
        transform: rotate(90deg);
      }

      .filter-body {
        padding-top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }

      .filter-group label {
        display: block;
        font-family: var(--font-display);
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-dim);
        margin-bottom: 0.3rem;
      }

      .filter-input {
        width: 100%;
        background: var(--color-surface2);
        border: 1px solid var(--color-border);
        border-radius: 3px;
        color: var(--color-text);
        font-size: 0.82rem;
        padding: 0.3rem 0.55rem;
        font-family: var(--font-body);
      }

      .filter-input:focus {
        outline: none;
        border-color: var(--color-golddim);
      }

      .kind-pills {
        display: flex;
        gap: 4px;
      }

      .kind-pill {
        font-family: var(--font-display);
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        border: 1px solid var(--color-border);
        border-radius: 3px;
        padding: 0.25rem 0.6rem;
        cursor: pointer;
        transition: all 0.15s;
        color: var(--color-dim);
        background: transparent;
        text-decoration: none;
      }

      .kind-pill:hover {
        border-color: var(--color-golddim);
        color: var(--color-gold);
      }

      .kind-pill--active {
        border-color: var(--color-gold);
        color: var(--color-gold);
        background: var(--color-goldglow);
      }

      .filter-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 0.75rem;
      }

      .filter-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-family: var(--font-display);
        font-size: 0.56rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: var(--color-goldglow);
        border: 1px solid var(--color-golddim);
        color: var(--color-gold);
        border-radius: 3px;
        padding: 2px 7px;
      }

      .filter-tag a {
        color: inherit;
        text-decoration: none;
        opacity: 0.7;
      }

      .filter-tag a:hover {
        opacity: 1;
      }
    </style>

    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-10 items-start">

        <main class="flex-1 min-w-0">

          <div class="mb-8 pb-6" style="border-bottom:1px solid var(--color-border);">
            <p class="page-label">Albion Online</p>
            <h1 class="page-title">Search</h1>
          </div>

          <!-- Search form -->
          <form id="search-form" class="flex gap-3 mb-2" method="GET" action="/search">
            <% if (f.kind && f.kind !=='all' ) { %>
              <input type="hidden" name="kind" value="<%= escHtml(f.kind) %>" />
              <% } %>
                <% if (f.dateFrom) { %>
                  <input type="hidden" name="dateFrom" value="<%= escHtml(f.dateFrom) %>" />
                  <% } %>
                    <% if (f.dateTo) { %>
                      <input type="hidden" name="dateTo" value="<%= escHtml(f.dateTo) %>" />
                      <% } %>
                        <% if (f.gameUpdate) { %>
                          <input type="hidden" name="gameUpdate" value="<%= escHtml(f.gameUpdate) %>" />
                          <% } %>
                            <input type="text" name="q" value="<%= escHtml(q || '') %>"
                              placeholder="Search abilities, patches... e.g. bows/cursed or holy beam"
                              class="search-input" autofocus />
                            <button class="btn-search shrink-0" type="submit">Search</button>
          </form>

          <p
            style="font-size:0.8rem;color:var(--color-dim);margin-bottom:1.25rem;font-family:var(--font-display);letter-spacing:0.06em;">
            Tip: use <code
              style="background:var(--color-surface2);padding:1px 5px;border-radius:3px;font-size:0.78rem;color:var(--color-muted);">/</code>
            to highlight multiple terms &nbsp;·&nbsp; spaces for exact phrase &nbsp;·&nbsp;
            e.g. <code
              style="background:var(--color-surface2);padding:1px 5px;border-radius:3px;font-size:0.78rem;color:var(--color-muted);">bows/holy beam</code>
          </p>

          <!-- Filter bar -->
          <details class="filter-bar" <%=hasFilters ? 'open' : '' %>>
            <summary>
              <span class="arrow">›</span>
              Filters
              <% if (hasFilters) { %>
                <span style="color:var(--color-muted);font-size:0.56rem;margin-left:4px;">(active)</span>
                <% } %>
            </summary>
            <div class="filter-body">

              <div class="filter-group">
                <label>Type</label>
                <div class="kind-pills">
                  <% [['all','All'],['change','Changes'],['section','Entries']].forEach(function(opt) { %>
                    <% var pillActive=(f.kind===opt[0]) ? 'kind-pill--active' : '' ; %>
                      <a href="<%= filterUrl({ kind: opt[0] }) %>" class="kind-pill <%= pillActive %>">
                        <%= opt[1] %>
                      </a>
                      <% }); %>
                </div>
              </div>

              <form method="GET" action="/search" style="display:contents;">
                <input type="hidden" name="q" value="<%= escHtml(q || '') %>" />
                <input type="hidden" name="kind" value="<%= escHtml(f.kind || 'all') %>" />
                <input type="hidden" name="gameUpdate" value="<%= escHtml(f.gameUpdate || '') %>" />
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                  <div class="filter-group">
                    <label>From</label>
                    <input type="date" name="dateFrom" class="filter-input" value="<%= escHtml(f.dateFrom || '') %>" />
                  </div>
                  <div class="filter-group">
                    <label>To</label>
                    <input type="date" name="dateTo" class="filter-input" value="<%= escHtml(f.dateTo || '') %>" />
                  </div>
                </div>
                <div style="display:flex;gap:6px;">
                  <button type="submit" class="view-btn">Apply dates</button>
                  <% if (f.dateFrom || f.dateTo) { %>
                    <a href="<%= filterUrl({ dateFrom: '', dateTo: '' }) %>" class="view-btn">Clear dates</a>
                    <% } %>
                </div>
              </form>

            </div>
          </details>

          <!-- Active filter tags -->
          <% if (hasFilters || q) { %>
            <div class="filter-tags">
              <% if (q) { %>
                <span class="filter-tag">
                  "<%= escHtml(q) %>"
                    <a href="/search" title="Clear query">x</a>
                </span>
                <% } %>
                  <% if (f.kind && f.kind !=='all' ) { %>
                    <span class="filter-tag">
                      type: <%= escHtml(f.kind) %>
                        <a href="<%= filterUrl({ kind: 'all' }) %>" title="Remove">x</a>
                    </span>
                    <% } %>
                      <% if (f.dateFrom) { %>
                        <span class="filter-tag">
                          from <%= escHtml(f.dateFrom) %>
                            <a href="<%= filterUrl({ dateFrom: '' }) %>" title="Remove">x</a>
                        </span>
                        <% } %>
                          <% if (f.dateTo) { %>
                            <span class="filter-tag">
                              to <%= escHtml(f.dateTo) %>
                                <a href="<%= filterUrl({ dateTo: '' }) %>" title="Remove">x</a>
                            </span>
                            <% } %>
                              <% if (f.dateFrom || f.dateTo || (f.kind && f.kind !=='all' )) { %>
                                <% var clearHref=q ? '/search?q=' + encodeURIComponent(q) : '/search' ; %>
                                  <a href="<%= clearHref %>" class="filter-tag" style="opacity:0.6;">Clear all
                                    filters</a>
                                  <% } %>
            </div>
            <% } %>

              <!-- Result count -->
              <% if (q || hasFilters) { %>
                <p
                  style="font-size:0.88rem;color:var(--color-dim);font-style:italic;margin-bottom:1rem;font-family:var(--font-body);">
                  <% if (meta.total===0) { %>
                    No results<%= q ? ' for "' + escHtml(q) + '"' : '' %>
                      <% } else { %>
                        <%= meta.total %> result<%= meta.total !==1 ? 's' : '' %>
                            <%= q ? ' for "' + escHtml(q) + '"' : '' %>
                              <% if (meta.counts && f.kind==='all' ) { %>
                                <span style="color:var(--color-border);margin:0 4px;">·</span>
                                <span style="font-size:0.82rem;">
                                  <%= meta.counts.changes %> change<%= meta.counts.changes !==1 ? 's' : '' %>,
                                      <%= meta.counts.sections %> entr<%= meta.counts.sections !==1 ? 'ies' : 'y' %>
                                </span>
                                <% } %>
                                  <% if (meta.totalPages> 1) { %>
                                    <span style="color:var(--color-border);margin:0 4px;">·</span>
                                    page <%= meta.page %> of <%= meta.totalPages %>
                                        <% } %>
                                          <% } %>
                </p>

                <% if (results.length===0) { %>
                  <div class="text-center py-12" style="border:1px dashed var(--color-border);border-radius:4px;">
                    <p style="color:var(--color-dim);font-size:0.95rem;">No results. Try different keywords or adjust
                      the filters.</p>
                  </div>
                  <% } else { %>

                    <div class="flex flex-col gap-px">
                      <% results.forEach(function(r) { var slug=r.patchSlug || '' ; var pUrl=patchUrl(slug, q); var
                        isChange=r.kind==='change' ; var ability=isChange ? (r.ability || '' ) : '' ; var
                        anchor=ability.toLowerCase().replace(/[^a-z0-9]+/g, '-' ).replace(/^-|-$/g, '' ).substring(0,
                        60); var fullUrl=anchor ? pUrl + '#' + anchor : pUrl; var
                        fullUrlSafe=fullUrl.replace(/'/g, '&#39;' ); var pUrlSafe=pUrl.replace(/'/g, '&#39;' ); var
                        updateSlug=(r.gameUpdateSlug || '' ).replace(/'/g, '&#39;' ); %>

                        <div class="result-card fade-up" onclick="navTo('<%= fullUrlSafe %>')">
                          <div class="flex items-start justify-between gap-4">
                            <div class="flex-1 min-w-0">

                              <div class="result-breadcrumb">
                                <span class="kind-badge kind-badge--<%= r.kind %>">
                                  <%= r.kind==='change' ? 'Change' : 'Entry' %>
                                </span>
                                <% if (r.gameUpdateName) { %>
                                  <span class="crumb-link"
                                    onclick="event.stopPropagation();navTo('/updates/<%= updateSlug %>')">
                                    <%= escHtml(r.gameUpdateName) %>
                                  </span>
                                  <span class="sep">›</span>
                                  <% } %>
                                    <% if (r.patchName) { %>
                                      <span class="crumb-link"
                                        onclick="event.stopPropagation();navTo('<%= pUrlSafe %>')">
                                        <%= escHtml(r.patchName) %>
                                      </span>
                                      <span class="sep">›</span>
                                      <% } %>
                                        <span class="section-crumb">
                                          <%= escHtml(r.sectionHeading) %>
                                        </span>
                                        <% if (r.subsectionHeading) { %>
                                          <span class="sep">›</span>
                                          <span class="section-crumb">
                                            <%= escHtml(r.subsectionHeading) %>
                                          </span>
                                          <% } %>
                              </div>

                              <% if (isChange) { %>

                                <% if (ability) { %>
                                  <div class="result-ability"><%- highlightSnippet(ability, meta.terms) %></div>
                                  <% } %>

                                    <% if (r.stats && r.stats.length> 0) { %>
                                      <div class="flex flex-wrap gap-1.5 mb-2">
                                        <% r.stats.forEach(function(stat) { %>
                                          <span class="result-stat">
                                            <span class="rs-name"><%- highlightSnippet(stat.name, meta.terms) %></span>
                                            <span class="rs-from">
                                              <%= escHtml(stat.from) %>
                                            </span>
                                            <span class="rs-arr">-></span>
                                            <span class="rs-to">
                                              <%= escHtml(stat.to) %>
                                            </span>
                                          </span>
                                          <% }); %>
                                      </div>
                                      <% } %>

                                        <% if (r.notes && r.notes.length> 0) { %>
                                          <ul
                                            style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.2rem;">
                                            <% r.notes.slice(0, 3).forEach(function(note) { %>
                                              <li class="result-note"><%- highlightSnippet(note, meta.terms) %></li>
                                              <% }); %>
                                                <% if (r.notes.length> 3) { %>
                                                  <li
                                                    style="font-size:0.82rem;color:var(--color-dim);padding-left:1.1rem;font-family:var(--font-display);letter-spacing:0.08em;">
                                                    +<%= r.notes.length - 3 %> more
                                                  </li>
                                                  <% } %>
                                          </ul>
                                          <% } %>

                                            <% } else { %>

                                              <% if (r.description) { %>
                                                <p class="section-desc"><%- highlightSnippet(r.description, meta.terms)
                                                    %></p>
                                                <% } %>
                                                  <% if (r.items && r.items.length> 0) { %>
                                                    <ul class="section-items">
                                                      <% r.items.slice(0, 4).forEach(function(item) { %>
                                                        <li class="section-item"><%- highlightSnippet(item, meta.terms)
                                                            %></li>
                                                        <% }); %>
                                                          <% if (r.items.length> 4) { %>
                                                            <li
                                                              style="font-size:0.8rem;color:var(--color-dim);padding-left:1.1rem;font-family:var(--font-display);letter-spacing:0.08em;">
                                                              +<%= r.items.length - 4 %> more
                                                            </li>
                                                            <% } %>
                                                    </ul>
                                                    <% } %>

                                                      <% } %>

                            </div>

                            <button class="view-btn mt-1" onclick="event.stopPropagation();navTo('<%= fullUrlSafe %>')">
                              View in patch
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                              </svg>
                            </button>
                          </div>

                          <div
                            style="margin-top:0.65rem;padding-top:0.65rem;border-top:1px solid var(--color-border);display:flex;align-items:center;gap:8px;">
                            <% if (r.patchVersion) { %>
                              <span class="tag tag-patch" style="font-size:0.52rem;">
                                <%= escHtml(r.patchVersion) %>
                              </span>
                              <% } %>
                                <span
                                  style="font-family:var(--font-display);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;color:var(--color-dim);">
                                  <%= new Date(r.patchDate).toLocaleDateString('en-GB', { day: '2-digit' ,
                                    month: 'short' , year: 'numeric' }) %>
                                </span>
                          </div>
                        </div>

                        <% }); %>
                    </div>

                    <% if (meta.totalPages> 1) { %>
                      <nav class="flex items-center justify-center gap-2 mt-10 pt-8"
                        style="border-top:1px solid var(--color-border);">
                        <% if (meta.page> 1) { %>
                          <a href="<%= filterUrl({ page: String(meta.page - 1) }) %>" class="page-btn">Prev</a>
                          <% } else { %>
                            <span class="page-btn-disabled">Prev</span>
                            <% } %>
                              <span class="page-btn-disabled">
                                <%= meta.page %> / <%= meta.totalPages %>
                              </span>
                              <% if (meta.page < meta.totalPages) { %>
                                <a href="<%= filterUrl({ page: String(meta.page + 1) }) %>" class="page-btn">Next</a>
                                <% } else { %>
                                  <span class="page-btn-disabled">Next</span>
                                  <% } %>
                      </nav>
                      <% } %>

                        <% } %>
                          <% } %>

        </main>

        <aside class="w-full lg:w-[300px] shrink-0 flex flex-col gap-6 lg:sticky lg:top-6">

          <div
            style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:4px;padding:1.25rem;">
            <p
