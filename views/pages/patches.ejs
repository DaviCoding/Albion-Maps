<% locals.currentPath='/updates/' + update.slug; const title=update.name; %>
  <%- include('../partials/_head', { title }) %>
    <%- include('../partials/_header') %>

      <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col lg:flex-row gap-8 lg:gap-10 items-start">

          <!-- Main -->
          <main class="flex-1 min-w-0">

            <a class="back-link" href="/updates">← Updates</a>

            <div class="mb-8">
              <div class="flex items-center gap-3 flex-wrap mb-4">
                <span class="tag tag-update">Game Update</span>
                <% if (update.releaseDate) { %>
                  <span class="detail-date">
                    <%= new Date(update.releaseDate).toLocaleDateString('en-GB', { day: '2-digit' , month: 'long' ,
                      year: 'numeric' }) %>
                  </span>
                  <% } %>
              </div>
              <h1 class="detail-title mb-1">
                <%= update.name %>
              </h1>
              <% if (update.description) { %>
                <div class="summary-block">
                  <%= update.description %>
                </div>
                <% } %>
            </div>

            <% if (patches && patches.length> 0) { %>
              <div class="section-rule">Patches — <%= patches.length %>
              </div>
              <div class="flex flex-col gap-px">
                <% patches.forEach(function(p) { %>
                  <a class="card-item fade-up" href="/patches/<%= p.slug %>" style="padding: 1rem 1.25rem;">
                    <div class="flex items-start justify-between gap-4 mb-1">
                      <span class="card-title">
                        <%= p.patchName %>
                      </span>
                      <span class="card-date shrink-0">
                        <%= new Date(p.dateIso).toLocaleDateString('en-GB', { day: '2-digit' , month: 'short' ,
                          year: 'numeric' }) %>
                      </span>
                    </div>
                    <% if (p.description) { %>
                      <p class="card-summary mb-2">
                        <%= p.description %>
                      </p>
                      <% } %>
                        <% if (p.keywords && p.keywords.length> 0) { %>
                          <div class="flex gap-1.5 flex-wrap mt-2">
                            <% p.keywords.slice(0, 5).forEach(function(kw) { %>
                              <span class="tag tag-patch" style="font-size:0.55rem;">
                                <%= kw %>
                              </span>
                              <% }); %>
                                <% if (p.keywords.length> 5) { %>
                                  <span class="tag"
                                    style="background:transparent;color:var(--color-dim);border-color:var(--color-border);font-size:0.55rem;">+
                                    <%= p.keywords.length - 5 %></span>
                                  <% } %>
                          </div>
                          <% } %>
                  </a>
                  <% }); %>
              </div>
              <% } else { %>
                <p class="text-center py-12"
                  style="color:var(--color-dim);border:1px dashed var(--color-border);border-radius:4px;font-size:0.95rem;">
                  No patches for this update.
                </p>
                <% } %>

          </main>

          <!-- Sidebar -->
          <aside class="w-full lg:w-[300px] shrink-0 flex flex-col gap-6 lg:sticky lg:top-6">
            <%- include('../partials/_ad-rect') %>

              <!-- Update meta -->
              <div
                style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:4px;padding:1.25rem;">
                <p
                  style="font-family:var(--font-display);font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-golddim);margin-bottom:0.75rem;">
                  Summary</p>
                <div style="display:flex;flex-direction:column;gap:0.6rem;">
                  <div style="display:flex;justify-content:space-between;align-items:center;">
                    <span
                      style="font-size:0.82rem;color:var(--color-dim);font-family:var(--font-display);font-size:0.65rem;letter-spacing:0.1em;font-weight:700;text-transform:uppercase;">Patches</span>
                    <span
                      style="font-family:var(--font-display);font-size:0.8rem;font-weight:700;color:var(--color-text);">
                      <%= patches.length %>
                    </span>
                  </div>
                  <% if (update.releaseDate) { %>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                      <span
                        style="font-size:0.82rem;color:var(--color-dim);font-family:var(--font-display);font-size:0.65rem;letter-spacing:0.1em;font-weight:700;text-transform:uppercase;">Released</span>
                      <span
                        style="font-family:var(--font-display);font-size:0.75rem;font-weight:700;color:var(--color-muted);">
                        <%= new Date(update.releaseDate).getFullYear() %>
                      </span>
                    </div>
                    <% } %>
                </div>
              </div>
          </aside>

        </div>
      </div>

      <%- include('../partials/_footer') %>