<div class="w-full max-w-[1280px] mx-auto px-6 py-8">

    <!-- Header -->
    <header class="border-b border-zinc-800 pb-6 mb-8">
        <p class="text-xs tracking-[0.2em] uppercase mb-2 text-amber-500" style="font-family:'Cinzel',serif">Albion
            Online</p>
        <h1 class="text-3xl font-bold text-white" style="font-family:'Cinzel',serif">Game Updates</h1>
        <p class="text-sm mt-2 text-zinc-500">
            <%= updates.length %> updates · <%= updates.reduce((a, u)=> a + u.changelogs.length, 0) %> patch notes
        </p>
    </header>

    <!-- Ad top 970x90 -->
    <div
        class="w-full h-[90px] mb-8 rounded flex items-center justify-center text-xs tracking-widest uppercase bg-zinc-900 border border-dashed border-zinc-800 text-zinc-600">
        Ad · 970×90
    </div>

    <!-- Updates -->
    <div class="space-y-4">
        <% updates.forEach((update, i)=> { %>
            <div class="rounded-lg overflow-hidden bg-zinc-900 border border-zinc-800">

                <!-- Update header — clicável -->
                <button class="w-full flex items-center gap-4 px-5 py-4 text-left transition-colors hover:bg-zinc-800"
                    onclick="toggleUpdate(this)" aria-expanded="<%= i === 0 ? 'true' : 'false' %>">
                    <% if (update.thumbnail) { %>
                        <img src="https:<%= update.thumbnail %>" alt="<%= update.name %>"
                            class="w-12 h-12 rounded object-cover shrink-0 border border-zinc-700">
                        <% } %>

                            <div class="flex-1 min-w-0 text-left">
                                <h2 class="text-sm font-bold text-white" style="font-family:'Cinzel',serif">
                                    <%= update.name %>
                                </h2>
                                <p class="text-xs mt-0.5 text-zinc-500">
                                    <%= update.date %>
                                </p>
                            </div>

                            <div class="flex items-center gap-3 shrink-0">
                                <span class="text-xs px-2.5 py-1 rounded-full bg-zinc-950 text-zinc-500">
                                    <%= update.changelogs.length %> patches
                                </span>
                                <svg class="chevron text-zinc-500 transition-transform duration-200 <%= i === 0 ? 'rotate-180' : '' %>"
                                    width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="18 15 12 9 6 15" />
                                </svg>
                            </div>
                </button>

                <!-- Patch list -->
                <div class="patch-list <%= i === 0 ? '' : 'hidden' %>">
                    <% if (update.changelogs.length) { %>
                        <div class="px-5 pb-3 pt-1 space-y-0.5">
                            <% update.changelogs.forEach(changelog=> { %>
                                <a href="/changelogs/<%= changelog.slug %>"
                                    class="flex items-center justify-between px-4 py-2.5 rounded-md transition-colors hover:bg-zinc-800 group">

                                    <div class="flex items-center gap-3 min-w-0">
                                        <span class="w-1 h-1 rounded-full bg-amber-700 shrink-0"></span>
                                        <span
                                            class="text-sm text-zinc-300 group-hover:text-white transition-colors truncate">
                                            <%= changelog.title %>
                                        </span>
                                    </div>

                                    <div class="flex items-center gap-4 shrink-0 ml-4">
                                        <% if (changelog.date) { %>
                                            <span class="text-xs text-zinc-600 hidden sm:block">
                                                <%= changelog.date %>
                                            </span>
                                            <% } %>
                                                <svg class="text-zinc-700 group-hover:text-zinc-400 transition-colors"
                                                    width="13" height="13" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path d="m9 18 6-6-6-6" />
                                                </svg>
                                    </div>
                                </a>
                                <% }) %>
                        </div>
                        <% } else { %>
                            <p class="px-5 pb-4 text-xs text-zinc-600">No patch notes available</p>
                            <% } %>
                </div>

            </div>
            <% }) %>
    </div>

</div>

<script>
    function toggleUpdate(btn) {
        const list = btn.nextElementSibling
        const chevron = btn.querySelector('.chevron')
        const isOpen = btn.getAttribute('aria-expanded') === 'true'

        list.classList.toggle('hidden')
        chevron.classList.toggle('rotate-180')
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
    }
</script>